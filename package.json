{
  "name": "bizen-platform",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "echo Run backend and frontend in two terminals: npm run dev:be && npm run dev:fe",
    "dev:be": "npm --prefix BE run dev",
    "dev:fe": "npm --prefix FE run dev",
    "build": "npm --prefix FE run build",
    "start": "npm --prefix BE run start",
    "db:migrate": "npm --prefix BE run db:migrate",
    "db:seed": "npm --prefix BE run db:seed"
  }
}
