  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1052.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "openai": "^6.38.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  }
}
