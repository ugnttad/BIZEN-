{
  "name": "bizen-platform",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "echo Run backend and frontend in two terminals: npm run dev:be && npm run dev:fe",
    "dev:be": "npm --prefix BE run dev",
    "dev:fe": "npm --prefix FE run dev",
