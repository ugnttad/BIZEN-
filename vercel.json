{
  "installCommand": "npm ci && npm ci --prefix BE && npm ci --prefix FE",
  "buildCommand": "npm --prefix FE run build",
  "outputDirectory": "FE/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
